# Telegram: создать у @BotFather
TELEGRAM_BOT_TOKEN=PASTE_TELEGRAM_BOT_TOKEN_HERE

# Узнать свой id можно у @userinfobot
ALLOWED_USER_ID=123456789

# OpenAI API key
OPENAI_API_KEY=PASTE_OPENAI_API_KEY_HERE
OPENAI_MODEL=gpt-4.1-mini

# Где агентам можно работать. Пути относительные от папки проекта и должны оставаться внутри неё.
WORKSPACE=jarvis\\workspace
DB_PATH=jarvis\\storage\\jarvis.db

# 0 = любые команды только после подтверждения кнопкой, 1 = безопасные команды можно без подтверждения
AUTO_APPROVE_SAFE_COMMANDS=0
