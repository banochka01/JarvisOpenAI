# Telegram: создать у @BotFather.
TELEGRAM_BOT_TOKEN=PASTE_TELEGRAM_BOT_TOKEN_HERE

# Узнать свой id можно у @userinfobot.
ALLOWED_USER_ID=123456789

# OpenAI API key.
OPENAI_API_KEY=PASTE_OPENAI_API_KEY_HERE
OPENAI_MODEL=gpt-4.1-mini

# Где агентам можно работать. Пути относительные от папки проекта и должны оставаться внутри неё.
WORKSPACE=jarvis\workspace
DB_PATH=jarvis\storage\jarvis.db

# 0 = любые команды только после подтверждения кнопкой, 1 = безопасные команды можно без подтверждения.
AUTO_APPROVE_SAFE_COMMANDS=0

# Speech-to-text для голосовых Telegram.
# openai = распознавать через OpenAI whisper-1.
# server = отправлять аудио на свой VPS STT-сервер из папки vps_stt_server/.
STT_PROVIDER=openai

# Используется только если STT_PROVIDER=server.
# Для прямого подключения: http://your-vps-ip:8008/transcribe
# Для reverse proxy/HTTPS: https://stt.your-domain.example/transcribe
STT_SERVER_URL=

# Bearer-токен VPS STT-сервера. Должен совпадать с STT_TOKEN на сервере.
STT_SERVER_TOKEN=CHANGE_ME_STT_SERVER_TOKEN

# Таймаут запроса к STT-серверу в секундах. Первый запрос может быть долгим из-за прогрева модели.
STT_SERVER_TIMEOUT=120

# HTTP/HTTPS proxy для исходящих запросов Python-клиентов, если сеть требует прокси.
# Обычно не нужно. Оставь пустым, если прокси нет.
# Формат: http://user:password@proxy-host:proxy-port
HTTP_PROXY=
HTTPS_PROXY=

# Хосты, которые должны обходить proxy. Полезно, если STT_SERVER_URL смотрит на локальный/внутренний адрес.
NO_PROXY=127.0.0.1,localhost

# Пути к локальным приложениям для /pc и голосовых команд.
# Можно указывать .lnk или .exe. Оставь пустым, если хочешь использовать web/protocol fallback.
PC_APP_YANDEX_MUSIC_PATH=
PC_APP_SPOTIFY_PATH=
PC_APP_VALORANT_PATH=
PC_APP_AYUGRAM_PATH=
